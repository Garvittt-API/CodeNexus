# CodeNexus Configuration

# Backend
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./data/codenexus.db

# Redis
REDIS_URL=redis://redis:6379/0

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32

# Re-ranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# LLM Provider (ollama | openai | anthropic | gemini | deepseek | mistral)
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# API Keys (only needed if using cloud providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Search
SEARCH_TOP_K=100
RERANK_TOP_K=20
EXPLAIN_TOP_K=3

# Indexing
MAX_CHUNK_TOKENS=512
OVERLAP_TOKENS=64
MAX_FILE_SIZE_MB=1
IGNORE_PATTERNS=.git,node_modules,venv,dist,build,.cache,target,coverage,__pycache__,*.pyc

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
